<?xml version="1.0"?>
<robot name="inverted_pendulum">

  <link name="base_link">
    <visual>
      <geometry>
        <box size="2.0 0.1 0.1"/>
      </geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
  </link>

  <link name="cart">
    <visual>
      <geometry>
        <box size="0.3 0.2 0.15"/>
      </geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
  </link>

  <joint name="cart_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="cart"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.9" upper="0.9" effort="100" velocity="10"/>
  </joint>

  <link name="pole">
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.5"/>
      </geometry>
      <material name="red"><color rgba="1 0 0 1"/></material>
    </visual>
  </link>

  <joint name="pole_joint" type="continuous">
    <parent link="cart"/>
    <child link="pole"/>
    <origin xyz="0 0 0.075" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

</robot>